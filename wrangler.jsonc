{
  "$schema": "node_modules/wrangler/config-schema.json",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "kaze.amia.work",
      "custom_domain": true,
    },
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "destinations": ["grafana-logs"],
    },
    "traces": {
      "enabled": true,
      "destinations": ["grafana-traces"],
    },
  },
  "placement": {
    "mode": "smart",
  },
  "compatibility_date": "2026-04-21",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "name": "fuwari-kaze",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "html_handling": "drop-trailing-slash",
  },
  "secrets_store_secrets": [
    {
      "binding": "TURNSTILE_SECRET",
      "store_id": "c5b03c1fc22547d0bb1ee70629d4b6dd",
      "secret_name": "TURNSTILE_SECRET",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "9514920d7aed43bb830548dbea4989f2",
    },
    {
      "binding": "HASH_KV",
      "id": "a819dd69e78849718fddb5ea6ff3fba7",
    },
  ],
  "images": {
    "binding": "IMAGES",
  },
}
